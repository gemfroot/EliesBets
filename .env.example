# Copy to `.env.local` for development. Set these in Vercel (or your host) for production.
#
# Security: after platform incidents, review & rotate secrets in Vercel; mark values as
# "Sensitive" where offered. See docs/VERCEL-SECURITY-RESPONSE.md and:
# https://vercel.com/kb/bulletin/vercel-april-2026-security-incident

# Required for production SEO, sitemap, Open Graph — use your real origin (https://yourdomain.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: log claim failures to the browser console in production (JSON with orderId / LP / flags).
# NEXT_PUBLIC_CLAIM_DEBUG=1

# Optional: WalletConnect Cloud project ID (https://cloud.walletconnect.com). If unset, injected + MetaMask still work.
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Sports launch: casino routes redirect to "/" unless enabled (see src/middleware.ts).
# Set to "true" only when casino is ready for real use.
NEXT_PUBLIC_CASINO_ENABLED=false

# Optional: affiliate wallet for casino games (defaults to connected wallet).
# NEXT_PUBLIC_CASINO_AFFILIATE=0x0000000000000000000000000000000000000000

# Optional overrides for BetSwirl / forked casino contract addresses — see `src/lib/casino/addresses.ts`.
# NEXT_PUBLIC_CASINO_BANK_POLYGON=
# NEXT_PUBLIC_CASINO_BANK_GNOSIS=
# NEXT_PUBLIC_CASINO_BANK_AVALANCHE=
# NEXT_PUBLIC_CASINO_BANK_BASE=
# NEXT_PUBLIC_CASINO_COIN_TOSS_POLYGON=
# ... (see addresses.ts for full list)
